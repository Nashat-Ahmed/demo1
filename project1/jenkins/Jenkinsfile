pipeline {
    agent any

    environment {
        KUBECONFIG = "/var/lib/jenkins/.kube/config"
        IMAGE_NAME = "nodeapp"
        IMAGE_TAG = "${BUILD_NUMBER}"
        K8S_NAMESPACE = "default"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/Nashat-Ahmed/demo1.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ./project1/app
                """
            }
        }

        stage('Load Image to Kind') {
            steps {
                sh """
                kind load docker-image ${IMAGE_NAME}:${IMAGE_TAG} --name devops-cluster
                """
            }
        }

        stage('Verify Kubernetes Access') {
            steps {
                sh """
                echo "=== Testing Kubernetes Access ==="
                echo "KUBECONFIG: \$KUBECONFIG"
                echo "=== Kubeconfig contents (masked) ==="
                cat \$KUBECONFIG | grep -v token | grep -v password
                echo "=== Testing cluster access ==="
                kubectl cluster-info || true
                kubectl get nodes || true
                """
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh """
                sed -i 's|IMAGE_PLACEHOLDER|${IMAGE_NAME}:${IMAGE_TAG}|g' project1/kubernetes/deployment.yml
                
                echo "=== Applying Kubernetes manifests ==="
                kubectl apply -f project1/kubernetes/
                
                echo "=== Waiting for rollout ==="
                kubectl rollout status deployment/nodeapp -n ${K8S_NAMESPACE} --timeout=2m
                """
            }
        }

    }

    post {
        success {
            echo "Deployment finished successfully!"
            sh "kubectl get pods -n ${K8S_NAMESPACE} -l app=nodeapp"
        }

        failure {
            echo "Deployment failed, check logs."
        }
    }
}
