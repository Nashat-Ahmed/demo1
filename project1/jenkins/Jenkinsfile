pipeline {
    agent any

    environment {
        IMAGE_NAME = "nodeapp"
        IMAGE_TAG = "${BUILD_NUMBER}"
        K8S_NAMESPACE = "default"
        KIND_CLUSTER_NAME = "kind"
        DEPLOYMENT_FILE = "project1/kubernetes/deployment.yml"
        SERVICE_FILE = "project1/kubernetes/service.yml"
    }

    stages {
        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/Nashat-Ahmed/demo1.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('project1/app') {
                    sh '''
                    docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                    '''
                }
            }
        }

        stage('Load Image into Kind') {
            steps {
                sh '''
                kind load docker-image ${IMAGE_NAME}:${IMAGE_TAG} --name ${KIND_CLUSTER_NAME}
                kind load docker-image ${IMAGE_NAME}:latest --name ${KIND_CLUSTER_NAME}

                echo "=== Verifying image load in kind ==="
                docker exec ${KIND_CLUSTER_NAME}-control-plane crictl images | grep ${IMAGE_NAME} || true
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                mkdir -p /tmp/jenkins-k8s
                cp ${DEPLOYMENT_FILE} /tmp/jenkins-k8s/deployment.yml
                sed -i "s|IMAGE_PLACEHOLDER|${IMAGE_NAME}:${IMAGE_TAG}|g" /tmp/jenkins-k8s/deployment.yml

                kubectl apply -n ${K8S_NAMESPACE} -f /tmp/jenkins-k8s/deployment.yml
                kubectl apply -n ${K8S_NAMESPACE} -f ${SERVICE_FILE}

                kubectl rollout status deployment/nodeapp -n ${K8S_NAMESPACE} --timeout=3m
                kubectl get pods -n ${K8S_NAMESPACE} -l app=nodeapp
                '''
            }
        }
    }

    post {
        success {
            echo "=== Deployment Successful ==="
            sh '''
            kubectl get pods -n ${K8S_NAMESPACE} -l app=nodeapp
            kubectl get svc -n ${K8S_NAMESPACE}
            echo "Access your app via the NodePort service or port-forward."
            '''
        }
        failure {
            echo "=== Deployment Failed - Debug Information ==="
            sh '''
            kubectl get events -n ${K8S_NAMESPACE} --sort-by='.lastTimestamp' | tail -20
            kubectl describe deployment nodeapp -n ${K8S_NAMESPACE}
            kubectl get pods -n ${K8S_NAMESPACE} -l app=nodeapp
            kubectl logs -n ${K8S_NAMESPACE} -l app=nodeapp --tail=50
            '''
        }
    }
}
