pipeline {
    agent any

    environment {
        // Remove KUBECONFIG from environment or set it correctly
        IMAGE_NAME = "nodeapp"
        IMAGE_TAG = "${BUILD_NUMBER}"
        K8S_NAMESPACE = "default"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/Nashat-Ahmed/demo1.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ./project1/app
                docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Setup Kubernetes Context') {
            steps {
                sh """
                echo "=== Setting up Kubernetes context ==="
                # Copy kubeconfig from Jenkins home if needed
                if [ -f /var/lib/jenkins/.kube/config ]; then
                    mkdir -p ~/.kube
                    cp /var/lib/jenkins/.kube/config ~/.kube/config
                fi
                
                # Test connection
                kubectl config view
                kubectl config current-context
                kubectl cluster-info || true
                """
            }
        }

        stage('Load Image to Kind') {
            steps {
                sh """
                kind load docker-image ${IMAGE_NAME}:${IMAGE_TAG} --name devops-cluster
                kind load docker-image ${IMAGE_NAME}:latest --name devops-cluster
                """
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh """
                # Update the image tag in deployment
                sed -i 's|nodeapp:latest|${IMAGE_NAME}:${IMAGE_TAG}|g' project1/kubernetes/deployment.yml
                
                echo "=== Applying Kubernetes manifests ==="
                kubectl apply -f project1/kubernetes/
                
                echo "=== Waiting for rollout ==="
                kubectl rollout status deployment/nodeapp -n ${K8S_NAMESPACE} --timeout=2m
                """
            }
        }

    }

    post {
        success {
            echo "Deployment finished successfully!"
            sh "kubectl get pods -n ${K8S_NAMESPACE} -l app=nodeapp"
            sh "kubectl get svc -n ${K8S_NAMESPACE}"
        }

        failure {
            echo "Deployment failed, check logs."
        }
    }
}
