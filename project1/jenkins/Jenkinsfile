pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/Nashat-Ahmed/demo1.git'
            }
        }

        stage('Stop Existing App') {
            steps {
                sh '''
                echo "Stopping existing app..."
                kubectl scale deployment nodeapp --replicas=0
                kubectl delete pod -l app=nodeapp || true
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t nodeapp:latest ./app'
            }
        }

        stage('Load Image to Kind') {
            steps {
                sh 'kind load docker-image nodeapp:latest'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                echo "Restarting app..."
                kubectl scale deployment nodeapp --replicas=2
                kubectl rollout status deployment nodeapp
                '''
            }
        }

    }
}
