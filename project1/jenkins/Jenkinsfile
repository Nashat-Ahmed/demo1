pipeline {
    agent any

    environment {
        KUBECONFIG = "/var/lib/jenkins/.kube/config"  // Changed to Jenkins user's home
        IMAGE_NAME = "nodeapp"
        IMAGE_TAG = "${BUILD_NUMBER}"
        K8S_NAMESPACE = "default"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/Nashat-Ahmed/demo1.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ./project1/app
                """
            }
        }

        stage('Load Image to Kind') {
            steps {
                sh """
                kind load docker-image ${IMAGE_NAME}:${IMAGE_TAG} --name devops-cluster
                """
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh """
                sed -i 's|IMAGE_PLACEHOLDER|${IMAGE_NAME}:${IMAGE_TAG}|g' project1/kubernetes/deployment.yml
                
                # Verify kubeconfig is accessible
                echo "Testing kubectl access..."
                kubectl cluster-info
                
                # Apply the deployment
                kubectl apply -f project1/kubernetes/
                
                # Check rollout status
                kubectl rollout status deployment/nodeapp -n ${K8S_NAMESPACE}
                """
            }
        }

    }

    post {
        success {
            echo "Deployment finished successfully!"
            // Optional: Get deployment details
            sh "kubectl get pods -n ${K8S_NAMESPACE} -l app=nodeapp"
        }

        failure {
            echo "Deployment failed, check logs."
        }
    }
}
