pipeline {
    agent any

    environment {
        IMAGE_NAME = "nodeapp"
        IMAGE_TAG = "${BUILD_NUMBER}"
        K8S_NAMESPACE = "default"
    }

    stages {
        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/Nashat-Ahmed/demo1.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                cd project1/app
                docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Load Image to Kind') {
            steps {
                sh """
                kind load docker-image ${IMAGE_NAME}:${IMAGE_TAG} --name devops-cluster
                kind load docker-image ${IMAGE_NAME}:latest --name devops-cluster
                
                # Verify image is loaded
                echo "=== Images in Kind cluster ==="
                docker exec devops-cluster-control-plane crictl images | grep nodeapp
                """
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh """
                # Update deployment with new tag
                sed -i 's|image: nodeapp:latest|image: nodeapp:${IMAGE_TAG}|g' project1/kubernetes/deployment.yml
                
                # Apply manifests
                kubectl apply -f project1/kubernetes/
                
                # Wait for pods to be created
                sleep 5
                
                # Show pod status
                kubectl get pods -l app=nodeapp
                
                # Check if pods are running
                READY=\$(kubectl get deployment nodeapp -o jsonpath='{.status.readyReplicas}')
                if [ "\$READY" != "2" ]; then
                    echo "=== Not all pods are ready. Checking logs ==="
                    POD=\$(kubectl get pods -l app=nodeapp -o jsonpath='{.items[0].metadata.name}')
                    kubectl logs \$POD
                    kubectl describe pod \$POD
                fi
                
                # Wait for rollout
                kubectl rollout status deployment/nodeapp -n ${K8S_NAMESPACE} --timeout=3m
                """
            }
        }
    }

    post {
        success {
            echo "=== Deployment Successful ==="
            sh """
            kubectl get pods -l app=nodeapp
            kubectl get svc
            echo "Access your app at: http://localhost:30007"
            """
        }
        failure {
            echo "=== Deployment Failed - Debug Information ==="
            sh """
            kubectl get events --sort-by='.lastTimestamp' | tail -20
            kubectl describe deployment nodeapp
            kubectl get pods -l app=nodeapp
            kubectl logs -l app=nodeapp --tail=50
            """
        }
    }
}
